{
  "pages": [
    //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "Ligo生鲜团购",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true // 开启下拉刷新
      }
    },
    // 商品列表页
    {
      "path": "pages/goods/goods",
      "style": {
        "navigationBarTitleText": "生鲜商品",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/goods/detail",
      "style": {
        "navigationBarTitleText": "商品详情",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true
      }
    },
    // 拼团页
    {
      "path": "pages/group-buy/group-buy",
      "style": {
        "navigationBarTitleText": "发起拼团",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "微信一键登录",
        "navigationBarBackgroundColor": "#ffffff",
        "navigationBarTextStyle": "black"
      }
    },
    // AI食材助手页
    {
      "path": "pages/ai-food/ai-food",
      "style": {
        "navigationBarTitleText": "AI食材推荐",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    // 团长页
    {
      "path": "pages/leader/leader",
      "style": {
        "navigationBarTitleText": "团长中心",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true
      }
    },
    // 订单页
    {
      "path": "pages/order/order",
      "style": {
        "navigationBarTitleText": "我的订单",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white",
        "enablePullDownRefresh": true
      }
    },
    // 订单详情
    {
      "path": "pages/order/detail",
      "style": {
        "navigationBarTitleText": "订单详情",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    // 自提点页
    {
      "path": "pages/self-pick/self-pick",
      "style": {
        "navigationBarTitleText": "自提网点",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    // 收货地址
    {
      "path": "pages/address/address",
      "style": {
        "navigationBarTitleText": "收货地址",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    // 客服
    {
      "path": "pages/service/service",
      "style": {
        "navigationBarTitleText": "联系客服",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    // 常见问题
    {
      "path": "pages/faq/faq",
      "style": {
        "navigationBarTitleText": "常见问题",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    },
    // 关于我们
    {
      "path": "pages/about/about",
      "style": {
        "navigationBarTitleText": "关于我们",
        "navigationBarBackgroundColor": "#F08800",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white", // 全局导航栏文字默认白色
    "navigationBarTitleText": "邻里鲜拼", // 全局默认标题
    "navigationBarBackgroundColor": "#F08800", // 全局导航栏背景
    "backgroundColor": "#F8F8F8", // 页面背景色
    "backgroundTextStyle": "dark" // 下拉刷新文字颜色
  },
  // 配置底部tabBar
  "tabBar": {
    "color": "#666666", // 未选中态文字颜色
    "selectedColor": "#F08800", // 选中态匹配主色
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/goods/goods",
        "text": "商品",
        "iconPath": "static/tabbar/goods.png",
        "selectedIconPath": "static/tabbar/goods-active.png"
      },
      {
        "pagePath": "pages/order/order",
        "text": "订单",
        "iconPath": "static/tabbar/order.png",
        "selectedIconPath": "static/tabbar/order-active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine-active.png"
      }
    ]
  },
  // 添加 easycom 配置，实现自动按需引入 uni-ui 组件
  "easycom": {
    "autoscan": true,
    "custom": {
      // 正则匹配 uni- 开头的组件，自动去 node_modules 找
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  }
}
